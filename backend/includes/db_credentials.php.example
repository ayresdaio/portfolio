<?php
/**
 * =====================================================================
 * MODELO DE CONFIGURAÇÃO DE BASE DE DADOS (db_credentials.php.example)
 * =====================================================================
 * INSTRUÇÕES: 
 * 1. Duplique este ficheiro e renomeie-o para "db_credentials.php"
 *    na mesma diretoria (backend/includes/).
 * 2. Preencha as suas informações de alojamento e do servidor de email.
 * 3. O ficheiro real "db_credentials.php" está incluído no .gitignore
 *    e nunca será enviado para o GitHub, protegendo as suas passwords.
 * =====================================================================
 */

// --- Credenciais da Base de Dados (InfinityFree / Alojamento) ---
$_ENV['DB_HOST'] = 'sqlXXX.epizy.com';     // Substitua pelo seu host da BD (ex: sql201.epizy.com)
$_ENV['DB_NAME'] = 'nome_da_base_dados';    // O nome exato da base de dados (ex: if0_123456_portfolio)
$_ENV['DB_USER'] = 'utilizador_db';        // O seu utilizador do MySQL (ex: if0_123456)
$_ENV['DB_PASS'] = 'SUA_PASSWORD_AQUI';    // A sua palavra-passe de acesso do cPanel/MySQL

// --- Credenciais do Servidor SMTP de E-mail (Notificações) ---
$_ENV['SMTP_HOST'] = 'smtp.gmail.com';         // Endereço do servidor SMTP (Ex: smtp.gmail.com)
$_ENV['SMTP_USER'] = 'seu_email@gmail.com';     // O seu e-mail do Gmail para autenticação
$_ENV['SMTP_PASS'] = 'sua_app_password_aqui';  // Palavra-passe de Aplicação gerada no painel da Google
$_ENV['SMTP_PORT'] = '587';                    // Porta segura do SMTP (Normalmente 587 para TLS)
$_ENV['ADMIN_EMAIL'] = 'seu_email@gmail.com';  // E-mail que receberá as mensagens de contacto

// --- Carregamento no Servidor para Compatibilidade Global ---
foreach ($_ENV as $key => $value) {
    $_SERVER[$key] = $value;
}
