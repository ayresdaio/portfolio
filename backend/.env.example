# ---------------------------------------------------------------------
# Configuração da Base de Dados MySQL (InfinityFree)
# ---------------------------------------------------------------------
DB_HOST=sql310.infinityfree.com
DB_USER=if0_41973639
DB_PASS=SuaSenhaDaBaseDeDadosAqui
DB_NAME=if0_41973639_ayres

# ---------------------------------------------------------------------
# Configuração do SMTP do Brevo (Para envio de e-mails de segurança)
# ---------------------------------------------------------------------
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=seu_email_registado_no_brevo@exemplo.com
BREVO_SMTP_PASS=sua_chave_smtp_do_brevo_aqui

# ---------------------------------------------------------------------
# Configurações do Portfólio e do Administrador
# ---------------------------------------------------------------------
ADMIN_EMAIL=seu_email_pessoal_para_recuperar_senha@exemplo.com
ADMIN_USERNAME=admin
ADMIN_PASSWORD=SuaSenhaDeAcessoAdminSuperSegura

# Chave Secreta para encriptar e validar os cookies de sessão segura
# Pode gerar qualquer string longa e aleatória
JWT_SECRET=ChaveSuperSecretaAleatoriaParaValidacaoDeSessoes12345!

# ---------------------------------------------------------------------
